<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <Version>$(SquirixPackageVersion)</Version>
        <PackageVersion>$(SquirixPackageVersion)</PackageVersion>
        <AssemblyName>Squirix.Server</AssemblyName>
        <RootNamespace>Squirix.Server</RootNamespace>
        <PackageId>squirix.server</PackageId>
        <Authors>Squirix Team</Authors>
        <Description>Server runtime for Squirix — consistent-hash routing, WAL journal, snapshots, compaction, recovery, REST/gRPC hosting, health endpoints, Prometheus metrics, and OpenTelemetry journal tracing. Early preview.</Description>
        <RepositoryUrl>https://github.com/squirix/squirix</RepositoryUrl>
        <PackageProjectUrl>https://github.com/squirix/squirix</PackageProjectUrl>
        <PackageTags>dotnet;cache;distributed-cache;csharp;grpc;server;durability;journal;snapshot;opentelemetry</PackageTags>
        <PackageReleaseNotes>Squirix 0.1.0 first public preview. See https://github.com/squirix/squirix/blob/main/docs/release-notes/v0.1.0.md</PackageReleaseNotes>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <IsPackable>true</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <Protobuf Include="..\shared\transport\grpc\Protos\SquirixCache.proto" GrpcServices="Server;Client" ProtoRoot="..\shared\transport\grpc\Protos" Access="Internal"/>
        <Protobuf Include="Storage\Journaling\Protos\JournalEnvelope.proto" GrpcServices="Server" ProtoRoot="Storage\Journaling\Protos" Access="Internal"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Google.Protobuf"/>
        <PackageReference Include="Grpc.AspNetCore"/>
        <PackageReference Include="Grpc.Tools" PrivateAssets="All"/>
        <PackageReference Include="JetBrains.Annotations" PrivateAssets="All"/>
        <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer"/>
    </ItemGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
    </ItemGroup>

    <ItemGroup>
        <Compile Include="..\shared\transport\grpc\Mappers\GrpcStaleOwnerMarkers.cs" Link="Adapters\Grpc\Mappers\GrpcStaleOwnerMarkers.cs"/>
        <None Include="README.md" Pack="true" PackagePath="/"/>
    </ItemGroup>
</Project>
