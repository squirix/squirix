{
  "config": ".markdownlint.json",
  "globs": [
    "**/*.md"
  ],
  "ignores": [
    ".github/ISSUE_TEMPLATE/**",
    ".github/PULL_REQUEST_TEMPLATE.md",
    "AGENTS.md",
    "**/AGENTS.md",
    "**/.cursor/**",
    ".tools/**",
    "artifacts/**",
    "BenchmarkDotNet.Artifacts/**",
    "**/*.tmp.md"
  ]
}
