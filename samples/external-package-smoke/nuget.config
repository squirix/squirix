<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <clear/>
        <add key="squirix-local" value="../../artifacts/packages"/>
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3"/>
    </packageSources>
    <packageSourceMapping>
        <packageSource key="squirix-local">
            <package pattern="Squirix*"/>
        </packageSource>
        <packageSource key="nuget.org">
            <package pattern="Google.*"/>
            <package pattern="Grpc.*"/>
            <package pattern="Meziantou.*"/>
            <package pattern="Microsoft.*"/>
            <package pattern="SonarAnalyzer.*"/>
            <package pattern="StyleCop.*"/>
            <package pattern="System.*"/>
        </packageSource>
    </packageSourceMapping>
</configuration>
