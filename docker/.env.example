# Copy to .env in this directory for LOCAL release-compose testing only:
#   Copy-Item .env.example .env
#
# Values below match the public dev fixtures in docker-compose.yml.
# NEVER commit .env or reuse these values in staging or production.
# Generate per-environment secrets: docs/containerization.md#generate-per-environment-secrets

SQUIRIX_JWT_SIGNING_KEY=dev-squirix-docker-jwt-key!!!!!!
SQUIRIX_JWT_ISSUER=https://squirix.docker.dev
SQUIRIX_JWT_AUDIENCE=squirix
SQUIRIX_CLUSTER_MTLS_CERT_PFX_PASSWORD=dev-docker-mtls
